{
  "name": "inter-window-procedure-call",
  "private": true,
  "scripts": {
    "build": "pnpm -r --parallel --if-present run build",
    "dev": "pnpm -r --parallel --if-present run dev",
    "dev:web": "pnpm --filter web run dev",
    "lint": "pnpm -r --parallel --if-present run lint",
    "lint:fix": "pnpm -r --parallel --if-present run lint -- --fix",
    "format": "prettier --write \"**/*.{ts,tsx,md}\""
  },
  "devDependencies": {
    "prettier": "^3.2.5",
    "typescript": "^5.9.0"
  },
  "packageManager": "pnpm@8.15.6",
  "engines": {
    "node": ">=18"
  }
}
